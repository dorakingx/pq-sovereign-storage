# PQSP — local environment template
# Copy this file to `.env` at the repository root and fill in the blank values.
# Never commit `.env`; it is gitignored (root and `contracts/`). Only `.env.example` belongs in the repo.

# 0G Chain (EVM) JSON-RPC endpoint used by the CLI for live storage config and on-chain verification.
0G_CHAIN_RPC_URL=https://evmrpc-testnet.0g.ai

# Hex-encoded private key for signing (0x-prefixed or raw hex). Leave empty in this template.
#
# CRITICAL — Use a dedicated hackathon wallet funded with 0G testnet tokens only.
# Do NOT use a mainnet wallet, production keys, or any account that holds real funds.
# If this key leaks, you should only risk testnet assets on that throwaway wallet.
0G_PRIVATE_KEY=

# 0G Storage node URL used for live uploads and the `download` command.
0G_STORAGE_NODE_URL=https://rpc-storage-testnet-turbo.0g.ai

# Address of `PqspVerifier` on 0G testnet after you deploy it (required for EVM `verify` when set).
# Obtain this from the Foundry broadcast output or block explorer; paste the full 0x-prefixed address here.
PQSP_VERIFIER_CONTRACT_ADDRESS=
